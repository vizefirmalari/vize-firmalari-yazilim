# Kopyala: cp .env.example .env.local  —  ardından değerleri doldurun.
# Bu şablon güvenli biçimde repoya eklenebilir; gerçek anahtarları .env.local’e yazın.

NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# OAuth / e-posta doğrulama / şifre sıfırlama için tam kök URL (Vercel’de custom domain önerilir)
# NEXT_PUBLIC_SITE_URL=https://example.com
#
# Supabase Dashboard → Authentication → URL Configuration:
# - Redirect URLs: http://localhost:3000/** , https://example.com/**
# - Şifre sıfırlama: .../auth/callback yolu izin listesinde olmalı
