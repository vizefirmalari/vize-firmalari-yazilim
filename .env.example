# Kopyala: cp .env.example .env.local  —  ardından değerleri doldurun.
# Bu şablon güvenli biçimde repoya eklenebilir; gerçek anahtarları .env.local’e yazın.

NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# İşini Büyüt — havale bilgileri (firma paneli ödeme sayfası)
# GROWTH_PAYMENT_IBAN=TR00 0000 0000 0000 0000 0000 00
# GROWTH_PAYMENT_BANK_NAME=Örnek Bankası
# GROWTH_PAYMENT_ACCOUNT_HOLDER=Şirket Ünvanı A.Ş.

# Vercel üretim: https://www.vizefirmalari.com (asla http://localhost... yazmayın — OAuth redirect bozulur)
# İsteğe bağlı takma ad:
# NEXT_PUBLIC_APP_URL=https://www.vizefirmalari.com
# NEXT_PUBLIC_SITE_URL=https://www.vizefirmalari.com
#
# Kod, üretimde env yok veya localhost içeriyorsa https://www.vizefirmalari.com kullanır.
# Geliştirmede localhost için env’i http://localhost:3000 yapın veya boş bırakın.
#
# Supabase → Authentication → Redirect URLs:
#   https://www.vizefirmalari.com/auth/callback
#   https://vizefirmalari.com/auth/callback
#   http://localhost:3000/auth/callback  (geliştirme)
#
# Google Cloud → Authorized redirect URI yalnızca Supabase:
#   https://<proje-ref>.supabase.co/auth/v1/callback
