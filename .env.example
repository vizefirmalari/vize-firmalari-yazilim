# Kopyala: cp .env.example .env.local  —  ardından değerleri doldurun.
# Bu şablon güvenli biçimde repoya eklenebilir; gerçek anahtarları .env.local’e yazın.

NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# İşini Büyüt — havale bilgileri (firma paneli ödeme modalı; üretimde Vercel env’e de ekleyin)
GROWTH_PAYMENT_IBAN=TR850006701000000055445417
GROWTH_PAYMENT_BANK_NAME=Yapı Kredi
# Havale alıcısı (modalda “Alıcı” satırı; boş bırakılırsa kod varsayılanını kullanır)
# GROWTH_PAYMENT_ACCOUNT_HOLDER=Bugra Keser

# Vercel üretim: https://www.vizefirmalari.com (asla http://localhost... yazmayın — OAuth redirect bozulur)
# İsteğe bağlı takma ad:
# NEXT_PUBLIC_APP_URL=https://www.vizefirmalari.com
# NEXT_PUBLIC_SITE_URL=https://www.vizefirmalari.com
#
# Kod, üretimde env yok veya localhost içeriyorsa https://www.vizefirmalari.com kullanır.
# Geliştirmede localhost için env’i http://localhost:3000 yapın veya boş bırakın.
#
# Supabase → Authentication → Redirect URLs:
#   https://www.vizefirmalari.com/auth/callback
#   https://vizefirmalari.com/auth/callback
#   http://localhost:3000/auth/callback  (geliştirme)
#
# Google Cloud → Authorized redirect URI yalnızca Supabase:
#   https://<proje-ref>.supabase.co/auth/v1/callback

# IndexNow (Bing vb.) — 8–128 karakter, yalnızca [0-9A-Za-z-]. Kökte `/{anahtar}.txt` sunulur; repoya yazmayın.
# INDEXNOW_KEY=

# Reklam paneli — tahmini potansiyel müşteri (lead) model oranları (0–1 arası ondalık; boşsa kod varsayılanı).
# Sosyal: tıklama ≈ toplam aylık erişim × AD_SOCIAL_CLICK_FROM_REACH_RATE; lead ≈ tıklama × AD_SOCIAL_LEAD_FROM_CLICK_RATE
# Web: lead ≈ tekil kullanıcı × AD_WEB_LEAD_FROM_UNIQUE_USER_RATE
# AD_SOCIAL_CLICK_FROM_REACH_RATE=0.02
# AD_SOCIAL_LEAD_FROM_CLICK_RATE=0.03
# AD_WEB_LEAD_FROM_UNIQUE_USER_RATE=0.015
# Gösterim aralığı (tekil tahmin çarpanı): 0.5–1 ve 1–2 aralığında
# AD_LEAD_DISPLAY_RANGE_LOW=0.85
# AD_LEAD_DISPLAY_RANGE_HIGH=1.15
